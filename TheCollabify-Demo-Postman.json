{
  "info": {
    "name": "TheCollabify Demo Platform",
    "description": "Complete seller-creator workflow API testing",
    "version": "1.0.0"
  },
  "item": [
    {
      "name": "Demo Setup",
      "item": [
        {
          "name": "Create Demo Environment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/demo/create-demo-users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "demo", "create-demo-users"]
            },
            "description": "Creates complete demo environment with seller, 3 creators, campaign, conversation, and collaboration"
          }
        },
        {
          "name": "Get Demo Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/demo/demo-users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "demo", "demo-users"]
            }
          }
        },
        {
          "name": "Clean Demo Data",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/demo/clean-demo-data",
              "host": ["{{baseUrl}}"],
              "path": ["api", "demo", "clean-demo-data"]
            }
          }
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register Seller",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"seller@test.com\",\n  \"name\": \"My Fashion Brand\",\n  \"password\": \"TestPassword@123\",\n  \"role\": \"seller\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Register Creator",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"creator@test.com\",\n  \"name\": \"Sarah Creator\",\n  \"password\": \"TestPassword@123\",\n  \"role\": \"creator\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"seller@test.com\",\n  \"password\": \"TestPassword@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{sellerToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Seller Workflows",
      "item": [
        {
          "name": "Get Seller Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{sellerToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/sellers/profile",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sellers", "profile"]
            }
          }
        },
        {
          "name": "Create/Update Seller Profile",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{sellerToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyName\": \"My Fashion Brand\",\n  \"industry\": \"Fashion\",\n  \"websiteUrl\": \"https://mybrand.com\",\n  \"description\": \"Premium fashion collaborations\",\n  \"logo\": \"https://via.placeholder.com/200\",\n  \"budget\": 10000,\n  \"monthlyBudget\": 2000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/sellers/profile",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sellers", "profile"]
            }
          }
        },
        {
          "name": "Create Campaign",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{sellerToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Summer Collection Campaign\",\n  \"description\": \"Looking for creators to showcase summer collection\",\n  \"promotionType\": \"POSTS\",\n  \"category\": \"FASHION\",\n  \"budget\": 5000,\n  \"campaignGoal\": \"REACH\",\n  \"startDate\": \"2024-01-15\",\n  \"endDate\": \"2024-02-15\",\n  \"requirements\": {\n    \"minFollowers\": 50000,\n    \"minEngagementRate\": 5\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/sellers/campaign",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sellers", "campaign"]
            }
          }
        },
        {
          "name": "Get Seller Campaigns",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{sellerToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/sellers/campaigns",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sellers", "campaigns"]
            }
          }
        },
        {
          "name": "Get Matched Creators for Campaign",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{sellerToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/sellers/campaign/{{campaignId}}/matches",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sellers", "campaign", "{{campaignId}}", "matches"]
            }
          }
        },
        {
          "name": "Get Seller Collaborations",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{sellerToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/sellers/collaborations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sellers", "collaborations"]
            }
          }
        }
      ]
    },
    {
      "name": "Creator Workflows",
      "item": [
        {
          "name": "Get Creator Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{creatorToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/creators/profile",
              "host": ["{{baseUrl}}"],
              "path": ["api", "creators", "profile"]
            }
          }
        },
        {
          "name": "Create/Update Creator Profile",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{creatorToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"instagramUsername\": \"@sarahcreator\",\n  \"instagramProfileUrl\": \"https://instagram.com/sarahcreator\",\n  \"followerCount\": 150000,\n  \"engagementRate\": 8.5,\n  \"category\": \"FASHION\",\n  \"promotionTypes\": [\"POSTS\", \"REELS\", \"STORIES\"],\n  \"minPrice\": 500,\n  \"maxPrice\": 3000,\n  \"bio\": \"Fashion & lifestyle creator\",\n  \"availabilityStatus\": \"AVAILABLE_NOW\",\n  \"strengths\": [\"Photography\", \"Storytelling\", \"Engagement\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/creators/profile",
              "host": ["{{baseUrl}}"],
              "path": ["api", "creators", "profile"]
            }
          }
        },
        {
          "name": "Browse Campaigns",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{creatorToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/creators/campaigns?category=FASHION&sortBy=recent",
              "host": ["{{baseUrl}}"],
              "path": ["api", "creators", "campaigns"],
              "query": [
                {
                  "key": "category",
                  "value": "FASHION"
                },
                {
                  "key": "sortBy",
                  "value": "recent"
                }
              ]
            }
          }
        },
        {
          "name": "Get Campaign Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{creatorToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/creators/campaigns/{{campaignId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "creators", "campaigns", "{{campaignId}}"]
            }
          }
        },
        {
          "name": "Get Creator Collaborations",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{creatorToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/creators/collaborations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "creators", "collaborations"]
            }
          }
        }
      ]
    },
    {
      "name": "Messaging",
      "item": [
        {
          "name": "Get All Conversations",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{sellerToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/chat/conversations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "chat", "conversations"]
            }
          }
        },
        {
          "name": "Start New Conversation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{sellerToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"creatorId\": \"{{creatorId}}\",\n  \"promotionId\": \"{{campaignId}}\",\n  \"message\": \"Hey! We love your content. Want to collaborate on our summer campaign?\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/chat/message-request",
              "host": ["{{baseUrl}}"],
              "path": ["api", "chat", "message-request"]
            }
          }
        },
        {
          "name": "Get Conversation Messages",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{sellerToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/chat/{{conversationId}}/messages",
              "host": ["{{baseUrl}}"],
              "path": ["api", "chat", "{{conversationId}}", "messages"]
            }
          }
        },
        {
          "name": "Send Message (Seller)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{sellerToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"We offer $1500 for 2 posts and 1 reel. What do you think?\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/chat/{{conversationId}}/message",
              "host": ["{{baseUrl}}"],
              "path": ["api", "chat", "{{conversationId}}", "message"]
            }
          }
        },
        {
          "name": "Send Message (Creator)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{creatorToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Sounds great! I'm interested. When do you need the content?\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/chat/{{conversationId}}/message",
              "host": ["{{baseUrl}}"],
              "path": ["api", "chat", "{{conversationId}}", "message"]
            }
          }
        },
        {
          "name": "Accept Collaboration Offer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{creatorToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"agreedAmount\": 1500,\n  \"startDate\": \"2024-01-20\",\n  \"endDate\": \"2024-02-03\",\n  \"deliverables\": {\n    \"posts\": 2,\n    \"reels\": 1,\n    \"stories\": 3\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/chat/{{conversationId}}/accept",
              "host": ["{{baseUrl}}"],
              "path": ["api", "chat", "{{conversationId}}", "accept"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "sellerToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "creatorToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "campaignId",
      "value": "",
      "type": "string"
    },
    {
      "key": "conversationId",
      "value": "",
      "type": "string"
    },
    {
      "key": "creatorId",
      "value": "",
      "type": "string"
    }
  ]
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String             @id @default(uuid())
  email                String             @unique
  password             String?
  name                 String
  avatar               String?            @default("")
  googleId             String?            @unique
  authProvider         AuthProvider       @default(LOCAL)
  emailVerified        Boolean            @default(false)
  isActive             Boolean            @default(true)
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  lastLogin            DateTime?
  activeRole           Role?
  pgpPublicKey         String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  reliabilityScore     Float              @default(1.0)
  dailyAIQueryCount    Int                @default(0)
  lastAIQueryDate      DateTime?
  subscriptionTier     SubscriptionTier   @default(FREE)
  analytics            Analytics[]
  apiKeys              ApiKey[]
  brandProfile         BrandProfile?
  calendarEvents       CalendarEvent[]
  contentCalendars     ContentCalendar[]
  conversationsCreator Conversation[]     @relation("CreatorUser")
  conversationsSeller  Conversation[]     @relation("Seller")
  creatorProfile       CreatorProfile?
  sentMessages         Message[]          @relation("Sender")
  notifications        Notification[]
  sellerCampaigns      PromotionRequest[] @relation("SellerCampaigns")
  organizations        TeamMember[]       @relation("OrgUser")
  teamMemberships      TeamMember[]       @relation("MemberUser")
  userIntent           UserIntent?
  roles                UserRole[]

  @@index([activeRole])
  @@index([isActive])
  @@index([createdAt])
}

model UserRole {
  id       String   @id @default(uuid())
  userId   String
  type     Role
  password String
  addedAt  DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id])

  @@unique([userId, type])
}

model CreatorProfile {
  id                          String                 @id @default(uuid())
  userId                      String                 @unique
  instagramUsername           String?                @default("")
  instagramProfileUrl         String?                @default("")
  instagramVerified           Boolean                @default(false)
  lastVerifiedAt              DateTime?
  followerCount               Int                    @default(0)
  engagementRate              Float                  @default(0)
  category                    Category
  promotionTypes              PromotionType[]
  minPrice                    Float
  maxPrice                    Float
  bio                         String?
  isAvailable                 Boolean                @default(true)
  availabilityStatus          AvailabilityStatus     @default(AVAILABLE_NOW)
  availabilityUpdatedAt       DateTime               @default(now())
  engagementQuality           String?                @default("Medium")
  audienceAuthenticity        String?                @default("Medium")
  strengths                   String[]
  profileSummary              String?
  aiScore                     Int                    @default(50)
  lastAnalyzed                DateTime?              @default(now())
  location                    Json?
  willingToTravel             String?                @default("NO")
  collaborationTypes          String[]
  totalEarnings               Float                  @default(0)
  profileViews                Int                    @default(0)
  totalPromotions             Int                    @default(0)
  successfulPromotions        Int                    @default(0)
  averageRating               Float                  @default(0)
  leaderboardScore            Float                  @default(0)
  lastScoreUpdate             DateTime?              @default(now())
  createdAt                   DateTime               @default(now())
  updatedAt                   DateTime               @updatedAt
  onboardingCompleted         Boolean                @default(false)
  pastExperience              String?
  portfolioLinks              String[]
  profileCompletionPercentage Int                    @default(0)
  reliabilityScore            Float                  @default(1.0)
  followerMismatchPercentage  Float?
  followerRiskScore           String?
  selfReportedFollowers       Int                    @default(0)
  verificationLastUpdated     DateTime?
  verificationStatus          String                 @default("pending")
  verifiedBy                  String?
  verifiedFollowerRangeMax    Int?
  verifiedFollowerRangeMin    Int?
  compositeRiskScore          Float                  @default(0)
  riskContentInactivity       Float                  @default(0)
  riskEngagementAnomaly       Float                  @default(0)
  riskFollowerMismatch        Float                  @default(0)
  riskGrowthInstability       Float                  @default(0)
  riskLastCalculated          DateTime?
  riskLevel                   String                 @default("low")
  engagementRateWarning       Boolean                @default(true)
  followerRange               FollowerRange?
  followerRangeChangedAt      DateTime?
  profileLastEditedAt         DateTime?
  achievements                Achievement[]
  audienceProfile             AudienceProfile?
  availabilityCampaigns       AvailabilityCampaign[]
  conversations               Conversation[]
  user                        User                   @relation(fields: [userId], references: [id])
  qualityIndex                CreatorQualityIndex?
  matchedCampaigns            MatchedCreator[]
  acceptedCampaigns           PromotionRequest[]

  @@index([category])
  @@index([isAvailable])
  @@index([aiScore])
  @@index([totalEarnings])
  @@index([profileCompletionPercentage])
  @@index([location], type: Gin)
}

model Achievement {
  id               String         @id @default(uuid())
  creatorProfileId String
  badgeId          String
  earnedAt         DateTime       @default(now())
  creatorProfile   CreatorProfile @relation(fields: [creatorProfileId], references: [id])
}

model PromotionRequest {
  id                    String                   @id @default(uuid())
  sellerId              String
  title                 String
  description           String
  minBudget             Float
  maxBudget             Float
  promotionType         PromotionType[]
  targetCategory        Category[]
  minFollowers          Int
  maxFollowers          Int
  campaignGoal          CampaignGoal
  location              Json?
  locationType          String?                  @default("REMOTE")
  status                CampaignStatus           @default(OPEN)
  deadline              DateTime?
  completedAt           DateTime?
  acceptedCreatorId     String?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  calendarEvents        CalendarEvent[]
  feedbackRecords       CampaignFeedbackRecord[]
  predictions           CampaignPrediction[]
  contentCalendarEvents ContentCalendar[]
  conversations         Conversation[]
  matchedCreators       MatchedCreator[]
  acceptedCreator       CreatorProfile?          @relation(fields: [acceptedCreatorId], references: [id])
  seller                User                     @relation("SellerCampaigns", fields: [sellerId], references: [id])

  @@index([status])
  @@index([targetCategory])
  @@index([promotionType])
  @@index([createdAt])
  @@index([location], type: Gin)
}

model MatchedCreator {
  id            String           @id @default(uuid())
  promotionId   String
  creatorId     String
  matchScore    Int
  matchReason   String
  status        MatchStatus      @default(MATCHED)
  agreedAmount  Float?
  appliedAt     DateTime?
  respondedAt   DateTime?
  collaboration Collaboration?
  outcome       MatchOutcome?
  creator       CreatorProfile   @relation(fields: [creatorId], references: [id])
  promotion     PromotionRequest @relation(fields: [promotionId], references: [id])

  @@unique([promotionId, creatorId])
  @@index([status])
  @@index([promotionId, status])
}

model Conversation {
  id                   String                 @id @default(uuid())
  promotionId          String
  sellerId             String
  creatorUserId        String
  creatorProfileId     String?
  status               ConversationStatus     @default(ACTIVE)
  creatorAccepted      String                 @default("pending")
  sellerAccepted       String                 @default("accepted")
  lastMessageContent   String?
  lastMessageSenderId  String?
  lastMessageCreatedAt DateTime?
  unreadCountSeller    Int                    @default(0)
  unreadCountCreator   Int                    @default(0)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  creatorMsgCount      Int                    @default(0)
  isEscrowUnlocked     Boolean                @default(false)
  sellerMsgCount       Int                    @default(0)
  creatorProfile       CreatorProfile?        @relation(fields: [creatorProfileId], references: [id])
  creatorUser          User                   @relation("CreatorUser", fields: [creatorUserId], references: [id])
  promotion            PromotionRequest       @relation(fields: [promotionId], references: [id])
  seller               User                   @relation("Seller", fields: [sellerId], references: [id])
  deletions            ConversationDeletion[]
  messages             Message[]

  @@unique([promotionId, creatorUserId])
  @@index([sellerId, updatedAt])
  @@index([creatorUserId, updatedAt])
  @@index([status])
}

model ConversationDeletion {
  id             String       @id @default(uuid())
  conversationId String
  userId         String
  deletedAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  @@unique([conversationId, userId])
}

model Message {
  id                String       @id @default(uuid())
  conversationId    String
  senderId          String
  content           String
  isRead            Boolean      @default(false)
  readAt            DateTime?
  isEdited          Boolean      @default(false)
  editedAt          DateTime?
  isDeleted         Boolean      @default(false)
  deletedAt         DateTime?
  isEncrypted       Boolean      @default(false)
  encryptionVersion String?      @default("1.0")
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  conversation      Conversation @relation(fields: [conversationId], references: [id])
  sender            User         @relation("Sender", fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
  @@index([isRead])
}

model Analytics {
  id        String   @id @default(uuid())
  userId    String
  type      String
  period    String
  date      DateTime
  metrics   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, date])
  @@index([metrics], type: Gin)
}

model TeamMember {
  id                String     @id @default(uuid())
  organizationId    String
  userId            String
  role              TeamRole   @default(CONTRIBUTOR)
  status            TeamStatus @default(PENDING)
  permissions       Json
  invitedByUserId   String?
  invitedAt         DateTime?
  acceptedAt        DateTime?
  lastActive        DateTime?
  loginCount        Int        @default(0)
  notificationPrefs Json
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  organization      User       @relation("OrgUser", fields: [organizationId], references: [id])
  user              User       @relation("MemberUser", fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([permissions], type: Gin)
}

model OTP {
  id        String   @id @default(uuid())
  email     String
  otp       String
  purpose   String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, isRead])
}

model CalendarEvent {
  id          String            @id @default(uuid())
  userId      String
  title       String
  description String?
  startDate   DateTime          @map("start")
  endDate     DateTime          @map("end")
  type        String?
  platform    String?
  status      String?
  campaignId  String?
  url         String?
  meta        Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  campaign    PromotionRequest? @relation(fields: [campaignId], references: [id])
  user        User              @relation(fields: [userId], references: [id])

  @@index([userId, startDate])
}

model ContentCalendar {
  id            String            @id @default(uuid())
  creatorId     String
  campaignId    String?
  title         String
  description   String?
  platform      String
  contentType   String
  scheduledDate DateTime
  scheduledTime String?
  status        String            @default("scheduled")
  caption       String?
  hashtags      String[]
  mediaUrls     String[]
  tags          String[]
  notes         String?
  reminders     Json?
  performance   Json?
  postedAt      DateTime?
  postUrl       String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  campaign      PromotionRequest? @relation(fields: [campaignId], references: [id])
  creator       User              @relation(fields: [creatorId], references: [id])

  @@index([creatorId, scheduledDate])
}

model Subscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model ApiKey {
  id          String    @id @default(uuid())
  key         String    @unique
  userId      String?
  serviceName String
  description String?
  isActive    Boolean   @default(true)
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?
  rotatedFrom String?
  user        User?     @relation(fields: [userId], references: [id])

  @@index([key, isActive])
  @@index([expiresAt])
}

model DailyTraffic {
  id        String   @id @default(uuid())
  date      DateTime @db.Date
  path      String
  views     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([date, path])
  @@index([date])
}

model MatchFeedback {
  id           String   @id @default(uuid())
  matchId      String?
  userId       String
  targetUserId String
  action       String
  source       String
  meta         Json?
  createdAt    DateTime @default(now())

  @@index([userId, action])
  @@index([targetUserId])
  @@index([createdAt])
}

model MatchOutcome {
  id             String         @id @default(uuid())
  matchId        String         @unique
  status         String
  timeline       Json
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  matchedCreator MatchedCreator @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model Collaboration {
  id               String                     @id @default(uuid())
  matchId          String                     @unique
  startDate        DateTime?
  endDate          DateTime?
  milestones       Json?
  termsAccepted    Boolean                    @default(true)
  sellerFeedback   Json?
  creatorFeedback  Json?
  completedAt      DateTime?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  statusHistory    Json?
  statusUpdatedAt  DateTime                   @default(now())
  status           CollaborationStatus        @default(REQUESTED)
  deliverableItems String[]
  matchedCreator   MatchedCreator             @relation(fields: [matchId], references: [id])
  deliverables     CollaborationDeliverable[]
  disputes         CollaborationDispute[]
  feedbacks        CollaborationFeedback[]
  escrowPayment    EscrowPayment?

  @@index([status])
}

model UserIntent {
  id               String   @id @default(uuid())
  userId           String   @unique
  recentCategories String[]
  recentTags       String[]
  lastActive       DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id])
}

model FrictionEvent {
  id        String   @id @default(uuid())
  userId    String?
  type      String
  severity  String   @default("MEDIUM")
  meta      Json?
  createdAt DateTime @default(now())

  @@index([type])
  @@index([createdAt])
  @@index([userId])
}

model Embedding {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  text       String
  vector     Json
  model      String   @default("text-embedding-004")
  dimensions Int      @default(768)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([entityType, entityId])
  @@index([entityType])
  @@index([entityId])
}

model CreatorQualityIndex {
  id                      String         @id @default(uuid())
  creatorId               String         @unique
  score                   Float          @default(50)
  engagementConsistency   Float          @default(50)
  followerGrowthStability Float          @default(50)
  commentAuthenticity     Float          @default(50)
  postingFrequency        Float          @default(50)
  nicheAuthority          Float          @default(50)
  audienceRetention       Float          @default(50)
  fraudRiskScore          Float          @default(0)
  dataPoints              Int            @default(0)
  confidence              Float          @default(0.5)
  version                 Int            @default(1)
  computedAt              DateTime       @default(now())
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  history                 CQISnapshot[]
  creator                 CreatorProfile @relation(fields: [creatorId], references: [id])

  @@index([score])
  @@index([fraudRiskScore])
}

model CQISnapshot {
  id        String              @id @default(uuid())
  cqiId     String
  score     Float
  subscores Json
  metrics   Json
  createdAt DateTime            @default(now())
  cqi       CreatorQualityIndex @relation(fields: [cqiId], references: [id])

  @@index([cqiId, createdAt])
}

model CampaignPrediction {
  id                  String           @id @default(uuid())
  campaignId          String
  creatorId           String
  predictedEngagement Float
  predictedReach      Int
  predictedROI        Float
  confidenceInterval  Json
  riskScore           Float
  featureSnapshot     Json
  modelVersion        String           @default("v1.0")
  modelType           String           @default("gradient_boost")
  createdAt           DateTime         @default(now())
  campaign            PromotionRequest @relation(fields: [campaignId], references: [id])

  @@unique([campaignId, creatorId])
  @@index([campaignId])
  @@index([creatorId])
  @@index([modelVersion])
}

model CampaignFeedbackRecord {
  id                  String           @id @default(uuid())
  campaignId          String
  creatorId           String
  predictedEngagement Float?
  predictedROI        Float?
  predictedReach      Int?
  actualEngagement    Float?
  actualROI           Float?
  actualReach         Int?
  actualConversions   Int?
  creatorMetrics      Json
  brandCategory       Category
  contentFormat       PromotionType
  campaignDuration    Int?
  agreedAmount        Float?
  engagementError     Float?
  roiError            Float?
  modelVersion        String           @default("v1.0")
  status              String           @default("PENDING")
  completedAt         DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  campaign            PromotionRequest @relation(fields: [campaignId], references: [id])

  @@unique([campaignId, creatorId])
  @@index([brandCategory])
  @@index([status])
  @@index([modelVersion])
  @@index([createdAt])
}

model FraudSignal {
  id         String    @id @default(uuid())
  creatorId  String
  signalType String
  severity   String    @default("MEDIUM")
  confidence Float
  evidence   Json
  resolved   Boolean   @default(false)
  resolvedAt DateTime?
  resolvedBy String?
  createdAt  DateTime  @default(now())

  @@index([creatorId])
  @@index([signalType])
  @@index([severity])
  @@index([createdAt])
}

model AudienceProfile {
  id             String         @id @default(uuid())
  creatorId      String         @unique
  demographics   Json
  interests      Json
  brandFitScores Json
  authenticity   Float          @default(0.5)
  activeRatio    Float          @default(0.5)
  dataSource     String         @default("inferred")
  confidence     Float          @default(0.5)
  computedAt     DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  creator        CreatorProfile @relation(fields: [creatorId], references: [id])

  @@index([authenticity])
}

model ScoringWeightConfig {
  id              String   @id @default(uuid())
  name            String   @unique
  weights         Json
  campaignsUsed   Int      @default(0)
  avgSuccessRate  Float?
  optimizedFrom   String?
  optimizationLog Json?
  isActive        Boolean  @default(true)
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model MLModelVersion {
  id               String    @id @default(uuid())
  modelName        String
  version          String
  parameters       Json
  hyperparameters  Json?
  metrics          Json
  trainingDataSize Int       @default(0)
  trainingDuration Float?
  trainedAt        DateTime  @default(now())
  isProduction     Boolean   @default(false)
  deployedAt       DateTime?
  previousVersion  String?
  createdAt        DateTime  @default(now())

  @@unique([modelName, version])
  @@index([modelName, isProduction])
}

model WeightOptimizationRun {
  id               String    @id @default(uuid())
  previousWeights  Json
  newWeights       Json
  trigger          String
  beforeMetrics    Json
  afterMetrics     Json?
  campaignsSampled Int
  improvement      Float?
  applied          Boolean   @default(false)
  appliedAt        DateTime?
  rolledBack       Boolean   @default(false)
  createdAt        DateTime  @default(now())

  @@index([createdAt])
}

model AIUsageLog {
  id               String   @id @default(uuid())
  userId           String
  mode             String
  model            String   @default("gemini-1.5-flash")
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  latencyMs        Int      @default(0)
  success          Boolean  @default(true)
  errorMessage     String?
  createdAt        DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([mode])
  @@index([userId, createdAt])
}

model BrandProfile {
  id                   String   @id @default(uuid())
  userId               String   @unique
  brandName            String
  category             Category
  website              String?
  instagramBusinessUrl String?
  description          String?
  locationCity         String?
  locationState        String?
  locationCountry      String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id])

  @@index([category])
}

model AvailabilityCampaign {
  id                     String         @id @default(uuid())
  creatorProfileId       String
  creatorUserId          String
  niche                  Category
  locationCity           String?
  locationState          String?
  locationCountry        String?
  deliverablesOffered    String[]
  collaborationBudgetMin Float
  collaborationBudgetMax Float
  description            String?
  durationDays           Int
  expiresAt              DateTime
  isActive               Boolean        @default(true)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  creatorProfile         CreatorProfile @relation(fields: [creatorProfileId], references: [id])

  @@index([niche])
  @@index([isActive, expiresAt])
  @@index([locationCity])
}

model EscrowPayment {
  id                    String        @id @default(uuid())
  collaborationId       String        @unique
  brandUserId           String
  creatorUserId         String
  collaborationAmount   Float
  platformFee           Float
  totalDeposited        Float
  status                EscrowStatus  @default(PENDING_DEPOSIT)
  stripePaymentIntentId String?
  stripeTransferId      String?
  depositedAt           DateTime?
  releasedAt            DateTime?
  refundedAt            DateTime?
  notes                 String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  collaboration         Collaboration @relation(fields: [collaborationId], references: [id])

  @@index([brandUserId])
  @@index([creatorUserId])
  @@index([status])
}

model CollaborationDeliverable {
  id                String            @id @default(uuid())
  collaborationId   String
  submittedByUserId String
  revisionCount     Int               @default(0)
  maxRevisions      Int               @default(3)
  contentLinks      String[]
  screenshotUrls    String[]
  fileUrls          String[]
  description       String?
  status            DeliverableStatus @default(PENDING)
  revisionNotes     String?
  submittedAt       DateTime?
  reviewedAt        DateTime?
  approvedAt        DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  collaboration     Collaboration     @relation(fields: [collaborationId], references: [id])

  @@index([collaborationId, status])
}

model CollaborationDispute {
  id                String        @id @default(uuid())
  collaborationId   String
  raisedByUserId    String
  reason            String
  evidence          String[]
  status            DisputeStatus @default(OPEN)
  resolvedByAdminId String?
  resolutionNotes   String?
  resolvedAt        DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  collaboration     Collaboration @relation(fields: [collaborationId], references: [id])

  @@index([collaborationId])
  @@index([status])
}

model PlatformSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedBy String?
  updatedAt DateTime @updatedAt

  @@index([key])
}

model CollaborationFeedback {
  id                       String        @id @default(uuid())
  collaborationId          String
  submittedByUserId        String
  role                     String
  rating                   Int
  comment                  String?
  creatorProfessionalism   Int?
  campaignQuality          Int?
  overallBrandExperience   Int?
  brandCommunication       Int?
  campaignClarity          Int?
  overallCreatorExperience Int?
  createdAt                DateTime      @default(now())
  collaboration            Collaboration @relation(fields: [collaborationId], references: [id])

  @@unique([collaborationId, role])
  @@index([collaborationId])
}

enum Role {
  CREATOR
  SELLER
  ADMIN
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum PromotionType {
  REELS
  STORIES
  POSTS
  WEBSITE_VISIT
}

enum Category {
  Fashion
  Tech
  Fitness
  Food
  Travel
  Lifestyle
  Beauty
  Gaming
  Education
  Entertainment
  Health
  Business
  Art
  Music
  Sports
  Other
}

enum CampaignGoal {
  REACH
  TRAFFIC
  SALES
}

enum CampaignStatus {
  OPEN
  CREATOR_INTERESTED
  ACCEPTED
  COMPLETED
  CANCELLED
}

enum MatchStatus {
  MATCHED
  INVITED
  APPLIED
  ACCEPTED
  REJECTED
}

enum ConversationStatus {
